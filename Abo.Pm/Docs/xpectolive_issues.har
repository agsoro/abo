            "mimeType": "application/javascript",
            "text": "function camelize(str) {\r\n  // returns string\r\n  if (str !== undefined) {\r\n    // turn filter ID into camel case\r\n    return str.replace(/(?:^\\w|[A-Z]|\\b\\w)/g, function (word, index) {\r\n      return index === 0 ? word.toLowerCase() : word.toUpperCase();\r\n    }).replace(/\\s+/g, \"\");\r\n  }\r\n  return undefined;\r\n}\r\nfunction getFilterDifference(array1, array2) {\r\n  // returns array of filters\r\n  return array1.filter(o1 => {\r\n    return !array2.some(o2 => {\r\n      return o1.id === o2.id;\r\n    });\r\n  });\r\n}\r\nfunction concatFilters(array1, array2) {\r\n  // returns array of filters\r\n  return array1.concat(array2);\r\n}\r\nfunction removeFilterByFilterValue(filters, filterValue) {\r\n  // return array of filters\r\n  return filters.filter(x => x.value !== filterValue);\r\n}\r\nfunction findIndexById(array, id) {\r\n  return array.findIndex(x => x?.id === id);\r\n}\r\nfunction findIndexByValue(array, value) {\r\n  return array.findIndex(x => x?.value === value);\r\n}\r\nfunction findFilterByValue(array, value) {\r\n  return array.find(x => x?.value === value);\r\n}\r\nfunction getInitFilter(name, filterParts, i18nValue) {\r\n  return {\r\n    id: camelize(name),\r\n    value: JSON.stringify({\r\n      filter: {\r\n        type: \"logic\",\r\n        logic: \"AND\",\r\n        parts: filterParts\r\n      }\r\n    }),\r\n    name: /*#__PURE__*/React.createElement(Xpecto.I18N, {\r\n      value: i18nValue,\r\n      fallback: name\r\n    })\r\n  };\r\n}\r\nfunction createFilteredList(db, idx, field, filterUnique) {\r\n  if (db?.data?.length > 0) {\r\n    return db.data.map(arr => arr?.[idx?.[field]]).filter(value => !!value)?.filter((value, index, array) => !filterUnique || array.indexOf(value) === index) // Apply uniqueness filter if filterUnique is true\r\n    .sort().map(el => [el]);\r\n  }\r\n  return [];\r\n}\r\nfunction createOptionList(list) {\r\n  if (list?.length > 0) {\r\n    return list?.map(el => ({\r\n      key: el?.[0],\r\n      value: el?.[0],\r\n      label: el?.[0]\r\n    }));\r\n  }\r\n  return [];\r\n}\r\nfunction saveFilter(filterName, filterValue, initFilters, filters, setFilters, setShowRenameModal, setShowOverwriteModal, resetNameField, updateUserParams) {\r\n  const nameRegex = /^(?=.*[a-zA-Z0-9])/;\r\n  if (!filterName || !nameRegex.test(filterName)) {\r\n    createNotification(\"error\", \"filter_name_error\", \"\", undefined, {\r\n      fallbacks: [\"Fehler: Filtername ist leer oder nicht gültig. Filter wurde nicht gespeichert.\", \"\"]\r\n    });\r\n    return;\r\n  }\r\n  const camelizedId = camelize(filterName);\r\n  if (!filterValue) {\r\n    createNotification(\"error\", \"filter_value_error\", \"\", undefined, {\r\n      fallbacks: [\"Fehler: Filterwert ist leer. Filter wurde nicht gespeichert.\", \"\"]\r\n    });\r\n    return;\r\n  }\r\n  if (filterName?.length > 50) {\r\n    createNotification(\"error\", \"filter_name_too_long_error\", \"\", undefined, {\r\n      fallbacks: [\"Fehler: Der eingegebene Filtername ist zu lang.\", \"\"]\r\n    });\r\n    return;\r\n  }\r\n  if (findIndexById(initFilters, camelizedId) !== -1 || findIndexByValue(initFilters, filterValue) !== -1) {\r\n    createNotification(\"error\", \"filter_overwrite_standard_error\", \"\", undefined, {\r\n      fallbacks: [\"Fehler: Standardfilter können nicht überschrieben werden.\", \"\"]\r\n    });\r\n    return;\r\n  }\r\n  if (findIndexByValue(filters, filterValue) !== -1) {\r\n    setShowRenameModal(prev => !prev);\r\n    return;\r\n  }\r\n  if (findIndexById(filters, camelizedId) !== -1) {\r\n    setShowOverwriteModal(prev => !prev);\r\n    return;\r\n  }\r\n  const newFiltersArray = [...filters, {\r\n    id: camelizedId,\r\n    value: filterValue,\r\n    name: filterName\r\n  }];\r\n  setFilters(newFiltersArray);\r\n  updateUserParams(newFiltersArray);\r\n  createNotification(\"success\", \"filter_saved_successfully\", \"\", undefined, {\r\n    fallbacks: [\"Neuer Filter