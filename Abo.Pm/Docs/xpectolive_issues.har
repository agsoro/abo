        "response": {
          "status": 200,
          "content": {
            "mimeType": "application/javascript",
            "text": "// @include(filter_helpers)\r\nconst XFORM_Container = () => {\r\n  const usersParameterKey = \"xpecto-cases-filters\";\r\n  const {\r\n    forms\r\n  } = useForms();\r\n  const {\r\n    data: user\r\n  } = useUser();\r\n  const {\r\n    setUserParameter,\r\n    useUserParameter\r\n  } = useXFormContext();\r\n  const {\r\n    value: filterValue\r\n  } = useURLFilter(\"filter\", true);\r\n  const {\r\n    data: userspecificFilters\r\n  } = useUserParameter(usersParameterKey);\r\n  const userFilter = JSON.stringify({\r\n    filter: {\r\n      type: \"logic\",\r\n      logic: \"AND\",\r\n      parts: [{\r\n        type: \"condition\",\r\n        field: \"98800\",\r\n        value: \"user\",\r\n        op: 0\r\n      }, {\r\n        type: \"condition\",\r\n        field: \"98805\",\r\n        value: \"\",\r\n        op: 1\r\n      }]\r\n    }\r\n  });\r\n  const {\r\n    data: dbAllUser,\r\n    indices: idxAllUser\r\n  } = useList(\"user.*\", {\r\n    filter: userFilter\r\n  });\r\n  const projectNullParts = [{\r\n    type: \"condition\",\r\n    op: 24,\r\n    field: \"7R500\",\r\n    value: \"- nicht zugeordnet -\"\r\n  }, {\r\n    type: \"condition\",\r\n    op: 1,\r\n    field: \"7R801\",\r\n    value: \"30\"\r\n  }];\r\n  const statusNullParts = [{\r\n    type: \"condition\",\r\n    op: 24,\r\n    field: \"7R801\",\r\n    value: \"-1\"\r\n  }];\r\n  const priorityNullParts = [{\r\n    type: \"condition\",\r\n    op: 24,\r\n    field: \"7R812\",\r\n    value: \"-1\"\r\n  }, {\r\n    type: \"condition\",\r\n    op: 1,\r\n    field: \"7R801\",\r\n    value: \"30\"\r\n  }];\r\n  const billingNullParts = [{\r\n    type: \"condition\",\r\n    op: 24,\r\n    field: \"7R054\",\r\n    value: \"-1\"\r\n  }, {\r\n    type: \"condition\",\r\n    op: 1,\r\n    field: \"7R801\",\r\n    value: \"30\"\r\n  }];\r\n  const userCreatedParts = [{\r\n    type: \"condition\",\r\n    op: 8,\r\n    field: \"7R904\",\r\n    value: [user?.user]\r\n  }];\r\n  const getCas