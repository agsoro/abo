osition: relative;\r\n  padding: 0;\r\n  margin: 0;\r\n  vertical-align: top;\r\n}\r\n\r\n.reportingheaders-invv-inline-edit-container {\r\n  border: none;\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  .XUI-Button-Text {\r\n    flex: 1 1 100%;\r\n    width: 100%;\r\n    height: 100%;\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: center;\r\n  }\r\n  .XUI-Form {\r\n    padding: 0px;\r\n    margin: 0px;\r\n    height: auto;\r\n    flex: 1 1 100%;\r\n    width: 100%;\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: center;\r\n    text-align: right;\r\n    .XUI-Helper {\r\n      display: none;\r\n    }\r\n\r\n    .XUI-InputNumber {\r\n      padding: 0px;\r\n    }\r\n  }\r\n}\r\ntd:has(.reportingheaders-invv-inline-edit-container .XUI-ItemWrapper:hover) {\r\n  box-shadow: 0 0 6px rgba(0, 0, 0, 0.4);\r\n  background-color: rgba(0, 0, 0, 0.05);\r\n  transition: all 0.2s ease-in-out;\r\n}\r\n\r\n.reportingheaders-invv-inline-edit-container:hover {\r\n  .XUI-ItemWrapper:hover {\r\n    cursor: cell !important;\r\n  }\r\n  background-color: transparent !important;\r\n}\r\n\r\n.global-immo-unit-tenant-tab-section-extra-button {\r\n  width: fit-content;\r\n}\r\n\r\nbutton.XUI-Accordion-Suffix-Icon:has(.remove_button_style) {\r\n  border: none !important;\r\n  outline: none !important;\r\n  background: transparent !important;\r\n}\r\n\r\nbutton.XUI-Accordion-Suffix-Icon:has(.icon_margin_right) {\r\n  margin-right: 3px !important;\r\n}\r\n\r\nsection.XUI-Accordion-Content-Wrapper:has(.remove_accordion_padding) {\r\n  padding: 0 !important;\r\n  border: none !important;\r\n  .XUI-Accordion-Content {\r\n    padding: 0 !important;\r\n  }\r\n}\r\n\r\n.XUI-Accordion-Wrapper.remove_border {\r\n  border: none !important;\r\n  box-shadow: none !important;\r\n  background-color: var(--modal-bg) !importa