            "text": ".global-favourites-icon-filled {\r\n  color: var(--global-main-color);\r\n  .XUI-Icon {\r\n    fill: var(--global-main-color);\r\n  }\r\n}\r\n\r\n.global-favourites-app {\r\n  display: flex;\r\n\r\n  .global-favourites-app-star-action {\r\n    display: flex;\r\n\r\n    .global-favourites-app-star-action-width {\r\n      width: 95%;\r\n    }\r\n  }\r\n\r\n  .global-favourites-app-filter {\r\n    width: auto;\r\n    display: inline;\r\n    border: 2px solid transparent;\r\n    z-index: 2;\r\n    border-right: 1px solid #d9d9d9;\r\n    padding: 0 15px 15px;\r\n    transition: all 0.3s ease-in-out;\r\n  }\r\n\r\n  .global-favourites-app-filter-hidden {\r\n    display: none;\r\n  }\r\n}\r\n\r\n.global-accordion {\r\n  .XUI-Accordion-Header {\r\n    margin-right: 12px;\r\n    margin-bottom: 0;\r\n    font-weight: 500;\r\n    color: $main-color;\r\n    font-size: 20px;\r\n    line-height: 32px;\r\n    overflow: hidden;\r\n    white-space: nowrap;\r\n    text-overflow: ellipsis;\r\n  }\r\n  .XUI-Accordion-Suffix-Icon {\r\n    border: none;\r\n    background: none;\r\n  }\r\n}\r\n\r\n.base-import-columnconfig-button-container {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  margin-right: 10px;\r\n}\r\n\r\n.global-accordion-white-background {\r\n  .XUI-Accordion {\r\n    border-radius: var(--global-border-radius);\r\n    background: #fff;\r\n  }\r\n\r\n  .XUI-Accordion-Header {\r\n    background: #fff;\r\n  }\r\n  .XUI-Accordion-Content-Wrapper {\r\n    background: #fff;\r\n  }\r\n}\r\n\r\n.global-custom-element-with-badge {\r\n  display: flex;\r\n  flex-direction: column;\r\n  position: relative;\r\n\r\n  .global-custom-element-with-badge-position {\r\n    position: absolute;\r\n    right: 0px;\r\n    top: 5px;\r\n  }\r\n}\r\n\r\n.global-flex-center-horizontal-vertical {\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  align-items: center;\r\n}\r\n\r\n.investor-products-quickadd-modal-footer {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: flex-end;\r\n  gap: 12px;\r\n}\r\n\r\n.investor-products-tabpane-section-extra-combobox-style {\r\n  margin-top: -15px;\r\n}\r\n\r\n.investor-product_smartcontract_loading_spinner {\r\n  display: flex;\r\n  justify-content: center;\r\n  font-size: 1.5em;\r\n  margin-top: 2em;\r\n}\r\n\r\n.convention-convention-delete-button {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.convention-convention-info-button-column {\r\n  display: flex;\r\n}\r\n\r\n.convention-convention-info-button {\r\n  margin-left: 4px;\r\n  font-size: 120%;\r\n  font-weight: 400;\r\n}\r\n\r\n.convention-convention-edit-attention-message {\r\n  color: red;\r\n}\r\n\r\n.xpecto-desk-cases-filter-combobox-width {\r\n  width: 320px;\r\n}\r\n\r\n.xpecto-desk-cases-section-placeholder-height {\r\n  height: 400px;\r\n}\r\n\r\n.global-custom-element-small-split-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n\r\n  .global-custom-element-small-split-header-right-aligned {\r\n    text-align: right;\r\n  }\r\n}\r\n\r\n.immo-projects-gantt-container {\r\n  max-height: 81vh;\r\n  overflow-y: auto;\r\n  overflow-x: hidden;\r\n}\r\n\r\n.immo-projects-kanban-container {\r\n  width: 100%;\r\n  height: 100%;\r\n  border: 1px solid transparent;\r\n  display: flex;\r\n}\r\n\r\n.immo-projects-kanban-filter {\r\n  width: auto;\r\n  display: none;\r\n  border: 2px solid transparent;\r\n}\r\n\r\n.immo-projects-kanban-searchbox {\r\n  margin-top: 0.55rem;\r\n}\r\n\r\n.base-events-add-files-icon {\r\n  color: rgba(166, 166, 166, 0.5);\r\n  font-size: 52px;\r\n  cursor: pointer;\r\n}\r\n\r\n.base-events-add-files-container {\r\n  height: 20.3vh;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n}\r\n\r\n.base-events-button-spacing {\r\n  margin-right: 20px;\r\n}\r\n\r\n.base-events-custom-list-container {\r\n  flex-direction: row;\r\n  display: flex;\r\n  width: 260px;\r\n}\r\n\r\n.base-events-custom-list-left {\r\n  flex-grow: 1;\r\n  text-align: left;\r\n}\r\n\r\n.base-events-custom-list-right {\r\n  flex-grow: 1;\r\n  text-align: right;\r\n}\r\n\r\n.global-controlling-button {\r\n  margin-top: 22.5px;\r\n}\r\n.global-controlling-timeseries-modal-table table {\r\n  th:first-child,\r\n  td:first-child {\r\n    display: none;\r\n    width: 0;\r\n  }\r\n}\r\n\r\n.global-controlling-timeseries-modal {\r\n  background-color: $light-gray;\r\n}\r\n\r\n.global-custom-element-flex-container {\r\n  display: flex;\r\n\r\n  .global-custom-element-flex-grow {\r\n    flex-grow: 1;\r\n  }\r\n}\r\n\r\n.global-custom-element-flex-container-space-between-content {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.global-flex-row-center-gap {\r\n  display: flex;\r\n  gap: var(--xpecto-gap-size-s);\r\n  justify-content: center;\r\n}\r\n\r\n.global-green-bold-font {\r\n  color: var(--xui-color-success-500);\r\n  font-weight: 500;\r\n}\r\n\r\n.global-orange-bold-font {\r\n  color: var(--xui-color-warning-500);\r\n  font-weight: 500;\r\n}\r\n\r\n.global-red-bold-font {\r\n  color: var(--xui-color-danger-500);\r\n  font-weight: 500;\r\n}\r\n\r\n.sales-person-section-extras-element-next-to-reportparams {\r\n  margin-left: 12px;\r\n}\r\n\r\n.global-workflow-edit-button {\r\n  position: absolute;\r\n  right: 20px;\r\n  top: 10px;\r\n}\r\n\r\n.xpecto-academy-no-files-element-container {\r\n  min-height: 200px;\r\n}\r\n\r\n.xpecto-academy-videoplayer {\r\n  display: block;\r\n  margin-top: -30px;\r\n  height: 600px;\r\n}\r\n\r\n.investor-calculation_payment_transactions_blocked_icon {\r\n  font-size: 120%;\r\n  font-weight: 400;\r\n}\r\n\r\n.investor-calculation_payment_transactions_verified_icon {\r\n  font-size: 120%;\r\n  font-weight: 400;\r\n}\r\n\r\n.investor-calculation_payment_transactions_blocked_info {\r\n  color: red;\r\n  font-size: 100%;\r\n  font-weight: 400;\r\n}\r\n\r\n.investor-calculation_payment_transactions_chart_header {\r\n  text-align: center;\r\n  margin-bottom: 16px;\r\n  padding-right: 8%;\r\n}\r\n.investor-calculation_payment_transactions_combobox_style {\r\n  width: 100px;\r\n}\r\n\r\n.investor-calculation_payment_transactions_combobox_product_style {\r\n  width: 160px;\r\n}\r\n\r\n.investor-calculation_payment_transactions_datepicker_style {\r\n  width: 180px;\r\n}\r\n\r\n.global-infoboard-container {\r\n  display: flex;\r\n  width: 100%;\r\n}\r\n\r\n.global-infoboard-avatar-title {\r\n  display: flex;\r\n  align-items: center;\r\n  width: 100%;\r\n}\r\n\r\n.global-infoboard-project-title-details {\r\n  margin-left: 1em;\r\n  flex: 1;\r\n  min-width: 0;\r\n}\r\n\r\n.global-infoboard-title {\r\n  margin-bottom: -5px;\r\n  max-width: 40vw;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n\r\n  .XUI-Helper {\r\n    display: none;\r\n  }\r\n}\r\n\r\n.global-infoboard-avatar-title-copy-button {\r\n  margin-left: auto;\r\n}\r\n\r\n.global-infoboard-tag-margin {\r\n  margin-top: 0.5em;\r\n  margin-bottom: 0.5em;\r\n}\r\n\r\n.global-infoboard-nested-section {\r\n  padding-top: 0px;\r\n  padding-bottom: 0px;\r\n  padding-left: 0px;\r\n  box-shadow: none;\r\n}\r\n\r\n.global-kanban-board-wrapper {\r\n  width: 100%;\r\n  height: 92vh;\r\n  display: flex;\r\n}\r\n\r\n.global-kanban-board-filter-divider {\r\n  width: auto;\r\n  padding-right: 6px;\r\n  border-right: 2px solid lightgray;\r\n}\r\n\r\n.global-searchbox-width {\r\n  width: 230px;\r\n}\r\n\r\n.global-section-content-zero-padding-bottom {\r\n  .xpecto-section-content {\r\n    padding-bottom: 0px !important;\r\n  }\r\n}\r\n\r\n.global-text-overflow {\r\n  overflow: hidden;\r\n  white-space: break-word;\r\n}\r\n\r\n.global-span-nowrap {\r\n  span {\r\n    white-space: nowrap;\r\n  }\r\n}\r\n\r\n.immo-objects-avatar-wrapper {\r\n  margin-top: 12px;\r\n  text-align: left;\r\n  flex-grow: 1;\r\n  display: inline-flex;\r\n  flex-direction: row;\r\n  align-content: space-between;\r\n}\r\n\r\n.immo-objects-avatar-title {\r\n  margin-left: 0.5em;\r\n}\r\n\r\n.immo-objects-avatar-header-title {\r\n  margin-top: -8px;\r\n  margin-bottom: -5px;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n}\r\n.immo-objects-avatar-header-subtitle {\r\n  margin-top: -8px;\r\n  margin-bottom: -7px;\r\n  color: #00000073;\r\n  font-size: 14px;\r\n}\r\n\r\n.tooltip-child {\r\n  font-size: 11.2px !important;\r\n}\r\n\r\n.section-nolabel-combobox {\r\n  margin-bottom: -1.4rem;\r\n  width: 100%;\r\n  margin-right: -7.5rem;\r\n}\r\n\r\n.truncate {\r\n  display: inline-block;\r\n  max-width: 100%;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n}\r\n\r\n.wizard-infinite-add-button {\r\n  margin-bottom: 0.5rem;\r\n}\r\n\r\n.xpecto-cases-infoboard-tag {\r\n  overflow: hidden;\r\n  white-space: nowrap;\r\n  word-wrap: break-word;\r\n  word-break: break-all;\r\n}\r\n\r\n.xpecto-cases-infoboard-comment-hidden {\r\n  height: 400px;\r\n  overflow: auto;\r\n}\r\n\r\n.xpecto-cases-infoboard-comment-expanded {\r\n  height: auto;\r\n  overflow: hidden;\r\n}\r\n\r\n.xpecto-cases-checklist-word-break {\r\n  overflow-wrap: break-word;\r\n  word-break: break-word;\r\n}\r\n\r\n.global-flex-container {\r\n  display: flex;\r\n}\r\n\r\n.xpecto-cases-checklist-edit-mode {\r\n  width: 40px;\r\n}\r\n.xpecto-cases-checklist-task-edit {\r\n  flex: 1;\r\n}\r\n\r\n.xpecto-cases-action-bar {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.xpecto-cases-chat-submit-button {\r\n  text-align: right;\r\n}\r\n\r\n.global-fixed-margin {\r\n  margin: 5px;\r\n}\r\n\r\n.global-align-items-center {\r\n  align-items: center;\r\n}\r\n\r\n.global-flex-direction-column {\r\n  flex: 1;\r\n  flex-direction: column;\r\n}\r\n\r\n.xpecto-cases-htmlviewer {\r\n  height: 250px;\r\n  overflow: auto;\r\n  margin-right: 18px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.global-table-element-center {\r\n  display: inline-flex;\r\n}\r\n\r\n.global-form-disable-xui-helper {\r\n  .XUI-Helper {\r\n    display: none;\r\n  }\r\n}\r\n\r\n.global-warning-item {\r\n  font-size: var(--xui-font-size-s);\r\n  color: var(--form-item-helper-error-text);\r\n  margin-top: -20px;\r\n}\r\n\r\n.global-text-align-center {\r\n  text-align: center;\r\n}\r\n\r\n.global-red-color {\r\n  color: var(--global-red-color);\r\n}\r\n\r\n.global-green-color {\r\n  color: var(--global-green-color);\r\n}\r\n\r\n.xpecto-worktime-clock-display {\r\n  display: block;\r\n  font-size: 50px;\r\n  font-weight: 500;\r\n  text-align: center;\r\n  margin-top: 15px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.xpecto-worktime-info-display {\r\n  display: block;\r\n  font-size: 20px;\r\n  text-align: center;\r\n}\r\n\r\n.global-no-box-shadow {\r\n  box-shadow: none;\r\n}\r\n\r\n.xpecto-worktime-width {\r\n  width: 80%;\r\n}\r\n\r\n.shareholder-structure-slider-label {\r\n  margin-top: 2.5px;\r\n  text-align: center;\r\n}\r\n\r\n.shareholder-structure-slider {\r\n  margin-top: 12.5px;\r\n}\r\n\r\n.shareholder-structure-row-mandator-container {\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  white-space: nowrap;\r\n  padding: 5px;\r\n  border-radius: var(--global-border-radius);\r\n}\r\n\r\n.shareholder-structure-row-mandator:hover {\r\n  color: var(--global-main-color);\r\n  cursor: pointer;\r\n  text-decoration: underline;\r\n}\r\n\r\n.shareholder-structure-row-mandator-current {\r\n  background-color: var(--xui-color-primary-100);\r\n  padding: 5px;\r\n  border-radius: var(--global-border-radius);\r\n}\r\n\r\n.shareholder-structure-list-row-container:hover {\r\n  .shareholder-structure-row-mandator-current {\r\n    background: none;\r\n  }\r\n}\r\n\r\n.shareholder-structure-list-row-container {\r\n  display: grid;\r\n  grid-template-columns: 1fr auto auto auto auto;\r\n  width: 100%;\r\n  box-sizing: border-box;\r\n}\r\n.shareholder-structure-list-row-container-title {\r\n  display: grid;\r\n  width: 100%;\r\n  box-sizing: border-box;\r\n  margin-top: -2.5px;\r\n  border-bottom: 1px ridge;\r\n  padding-left: 10px;\r\n  grid-template-columns: 1fr 100px 100px 150px 100px;\r\n  position: sticky;\r\n  top: -1px;\r\n  z-index: 1;\r\n  background-color: white;\r\n}\r\n\r\n.shareholder-structure-list-col {\r\n  min-width: 100px;\r\n  padding: 0 10px;\r\n  text-align: right;\r\n}\r\n.shareholder-structure-list-col-title {\r\n  min-width: 100px;\r\n  padding: 0 10px;\r\n  text-align: right;\r\n  margin-left: 2.5px;\r\n}\r\n\r\n.shareholder-structure-list-col-left {\r\n  min-width: 100px;\r\n  padding: 0 10px;\r\n  text-align: left;\r\n}\r\n\r\n.immo-damages-text-explanation-container {\r\n  height: 350px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  text-align: center;\r\n}\r\n\r\n.global-immo-realty-project-tab-section-extra {\r\n  width: 180px;\r\n}\r\n\r\n.immo-agreements-plaintext-overflow {\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n\r\n  .xpecto-plaintext-container {\r\n    .xpecto-plaintext-text {\r\n      white-space: nowrap;\r\n      overflow: hidden;\r\n      text-overflow: ellipsis;\r\n      width: 100%;\r\n    }\r\n  }\r\n}\r\n\r\n.immo-agreements-plaintext-container {\r\n  display: flex;\r\n  max-width: 100%;\r\n}\r\n\r\n.global-anchor-style {\r\n  color: var(--xui-color-primary-500);\r\n}\r\n\r\n.immo-comparativeasset-switch-container {\r\n  margin-top: 0.4rem;\r\n}\r\n\r\n.global-comparativeasset-wizard-add-new-button {\r\n  margin-top: 22px;\r\n  margin-left: 3px;\r\n}\r\n\r\n.global-tabledefinition-open-button {\r\n  [class^=\"xpecto-column-align\"] {\r\n    .XUI-Button {\r\n      margin: -4px;\r\n    }\r\n  }\r\n}\r\n\r\n.shareholder-mandators-dashboard-container {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  height: 400px;\r\n}\r\n\r\n.shareholder-mandators-wizard-thumbnail-button {\r\n  margin-top: 22.5px;\r\n}\r\n\r\n.global-immo-tag-with-optional-tooltip-max-width {\r\n 