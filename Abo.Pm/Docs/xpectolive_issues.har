            "mimeType": "application/javascript",
            "text": "function convertMinsToTimeString(input) {\r\n  // input: minutes / output format: \"(-)HH:mm\"\r\n  if (input === null || input === undefined || Number.isNaN(input)) {\r\n    return null;\r\n  }\r\n  const totalMinutes = Math.abs(input);\r\n  const hours = Math.floor(totalMinutes / 60);\r\n  const minutes = Math.floor(totalMinutes % 60);\r\n  const sign = input < 0 ? \"-\" : \"\";\r\n  const paddedHours = String(hours).padStart(2, \"0\");\r\n  const paddedMinutes = String(minutes).padStart(2, \"0\");\r\n  return `${sign}${paddedHours}:${paddedMinutes}`;\r\n}\r\nfunction convertMinsToTimeStringVerbal(input) {\r\n  // input: minutes / output format: \"(-)HH Std mm Min\"\r\n  if (input === null || input === undefined || !Number.isFinite(Number(input))) {\r\n    return null;\r\n  }\r\n  const totalMinutes = Math.abs(input);\r\n  const hours = Math.floor(totalMinutes / 60);\r\n  const minutes = Math.floor(totalMinutes % 60);\r\n  const sign = input < 0 ? \"-\" : \"\";\r\n  return `${sign}${hours} Std ${minutes} Min`;\r\n}\r\nfunction getCasePriorityColor(priority) {\r\n  if (!priority || Number.isNaN(priority) || priority < 1 || priority > 5) return \"volcano\";\r\n  const priorityColors = [\"volcano\", \"gold\", \"geekblue\", \"cyan\", \"green\"];\r\n  return priorityColors[priority - 1];\r\n}\r\nfunction getCaseBillingColor(billing) {\r\n  if (billing === 9) return \"geekblue\";\r\n  if (!billing && billing !== 0 || Number.isNaN(billing) || billing < 0 || billing > 3) return \"volcano\";\r\n  const priorityColors = [\"purple\", \"gold\", \"cyan\", \"green\"];\r\n  return priorityColors[billing];\r\n}\r\nfunction getCasePriorityTag(value, priorityValue) {\r\n  return /*#__PURE__*/React.createElement(Xpecto.Tag, {\r\n    color: getCasePriorityColor(priorityValue),\r\n    icon: \"infoCircle\"\r\n  }, value || /*#__PURE__*/React.createElement(Xpecto.I18N, {\r\n    value: \"value_missing\",\r\n    fallback: \"Wert fehlt!\",\r\n    context: \"system\"\r\n  }));\r\n}\r\nfunction getCaseBillingTag(value, billingValue) {\r\n  return /*#__PURE__*/React.createElement(Xpecto.Tag, {\r\n    color: getCaseBillingColor(billingValue),\r\n    icon: \"currencyDollarCircle\"\r\n  }, value || /*#__PURE__*/React.createElement(Xpecto.I18N, {\r\n    value: \"value_missing\",\r\n    fallback: \"Wert fehlt!\",\r\n    context: \"system\"\r\n  }));\r\n}\r\nfunction getCommentTemplate(category) {\r\n  const templates = {\r\n    SystemError: [\"*WO (in welchem Programmteil):\", \"*WAS (genaue Fehlermeldung, kann mit Strg+C kopiert werden):\", \"*WOMIT ist der Fehler zu reproduzieren (z.B. ID des Kunden, Vertriebspartner, der Adresse, Berichtsname):\", \"*WANN ist der Fehler aufgetreten:\"].join(\"\\n\\n\\n\"),\r\n    UserAssistance: [\"*WAS ist das Ziel (Anwendungsfall formulieren: Ich möchte ... ):\", \"*HINTERGRUND (detaillierte Erläuterung, warum die gewünschte Umsetzung erforderlich ist bzw. die vorhandene Umsetzung nicht ausreicht.):\", \"*LÖSUNGSVORSCHLAG:\", \"*WOHER stammt die Anforderung (Kunde/Intern/Regulatorik):\", \"*WELCHE Software:\", \"*WO (in welchem Programmteil - an welcher Stelle (präzise) - System/Datenbank):\", \"*GENAUE Anforderung inkl. Prioritäten\\nMuss:\\nSoll:\\nKann:\", \"*WANN ist die zeitliche Umsetzung gewünscht (Deadlines?):\", \"*ZUSÄTZLICHE Informationen (Link/Wiki-Seite):\"].join(\"\\n\\n\\n\"),\r\n    Improvement: [\"*WAS ist das Ziel (Anwendungsfall formulieren: Ich möchte ... ):\", \"*HINTERGRUND (detaillierte Erläuterung, warum die gewünschte Umsetzung erforderlich ist bzw. die vorhandene Umsetzung nicht ausreicht.):\", \"*LÖSUNGSVORSCHLAG:\", \"*WOHER stammt die Anforderung (Kunde/Intern/Regulatorik):\", \"*WELCHE Software/Prozess:\", \"*WO (in welchem Programmteil - an welcher Stelle (präzise) - System/Datenbank):\", \"*WANN ist die zeitliche Umsetzung gewünscht (Deadlines?):\", \"*ZUSÄTZLICHE Informationen (Link/Wiki-Seite):\"].join(\"\\n\\n\\n\")\r\n  };\r\n  const categoryMapping = {\r\n    UserWork: \"UserAssistance\",\r\n    NewStuff: \"UserAssistance\",\r\n    PlanSection: \"Improvement\"\r\n  };\r\n  const templateKey = categoryMapping[category] || category;\r\n  return templates[templateKey] || \"\";\r\n}"
