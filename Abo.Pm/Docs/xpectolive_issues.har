            "text": "const footer = [\"Mit freundlichen Grüßen\", \"\", \"[signature]\", \"\", \"Telefon: [phone] | Telefax: +49 871 27671-29\", \"E-Mail: [email] | Web: www.xpecto.com\", \"\", \"xpecto AG | Ergoldinger Straße 2a | D-84030 Landshut\", \"Vorstand: Harald Elsperger (Vorsitzender), Armin Bart, Christian Schaupp\", \"Vorsitzender des Aufsichtsrats: Christoph Weber | Amtsgericht Landshut HRB 5763\", \"Datenschutzerklärung: www.xpecto.com/datenschutz\"].join(\"<br/>\");\r\nconst snippets = {\r\n  Erledigt: [\"Guten Tag,\", \"die Aufgabe ist erledigt.\", \"Bitte prüfen Sie die Änderungen/Erweiterungen an Ihrem System auf Vollständigkeit und Richtigkeit.\", footer].join(\"<br/><br/>\"),\r\n  Kopa: [\"Guten Tag,\", \"\", \"vielen Dank für Ihre Anfrage.\", \"\", \"Diese Umsetzung Ihrer Anforderung können wir Ihnen als kostenpflichtige Customizingleistung zum vereinbarten Tagessatz anbieten.\", \"\", \"Die folgenden Ziele/Aufgabenpakete haben wir aus Ihrer Anforderung abgeleitet:\", \"*…..\", \"*…..\", \"\", \"Der geschätzte Arbeitsaufwand hierfür beträgt [Estimated Hours].\", \"\", \"Für eine positive Freigabe können Sie gerne diese Mail beantworten oder uns telefonisch unter Angabe der Ticketnummer kontaktieren.\", \"Den gewünschten Zeitpunkt der Umsetzung können wir gerne nach Freigaben zusammen erörtern.\", \"\", \"Gerne bieten wir Ihnen vergünstigte Stundenkontingente an. Für weitere Information erreichen Sie uns unter vertrieb@xpecto.com.\", \"\", footer].join(\"<br/>\"),\r\n  \"Details anfordern\": [\"Guten Tag,\", \"aus der übermittelten Beschreibung können wir leider keine klare Anforderung ableiten.\", \"Bitte übersenden Sie uns weitere Details zu dieser Anfrage.\", footer].join(\"<br/><br/>\"),\r\n  \"Aufgabe zugewiesen\": [\"Guten Tag,\", \"diese Aufgabe wurde an den Mitarbeiter [User] übergeben. Er wird sich in Kürze bei Ihnen melden und den Zeitpunkt der Umsetzung mitteilen.\", footer].join(\"<br/><br/>\")\r\n};\r\nconst linebreaksToHtml = inputT