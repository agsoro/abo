          "content": {
            "mimeType": "application/javascript",
            "text": "/**\r\n * insert separator in array\r\n * @param arr array\r\n * @param sep separator\r\n * @returns array with separator elements between value elements\r\n */\r\nfunction intersperse(arr, sep) {\r\n  if (arr.length > 1) {\r\n    return arr.reduce((acc, val) => {\r\n      if (acc.length === 0) return [val];\r\n      return [...acc, sep, val];\r\n    }, []);\r\n  }\r\n  return arr;\r\n}\r\n\r\n/**\r\n * change list into optionList with translated labels\r\n *\r\n * listValueField and i18NValueField are \"73801\" if a lookuplist is used\r\n *\r\n * if the value to translate includes a | it is replaced by a _ as the I18N-Keys cannot include a |\r\n * @param db list\r\n * @param idx list indices\r\n * @param valueFields fieldIds of valueFields\r\n * @param labelFields fieldIds / I18N props of displayFields\r\n * @returns optionList with translated labels\r\n */\r\nfunction createTranslatedOptionList(db, idx, valueFields, labelFields) {\r\n  if (db?.data?.length > 0) {\r\n    return db?.data?.map(row => {\r\n      const valueArr = valueFields?.map(valueField => row?.[idx?.[valueField]]);\r\n      let value = valueArr?.[0];\r\n      if (valueArr?.length > 1) value = valueArr?.join();\r\n      // Bei einer Lookupliste ist der value ein String, auch wenn er eine Zahl wäre. => zur Zahl parsen\r\n      else if (valueFields?.[0] === \"73801\" && typeof value === \"string\" && !Number.isNaN(parseInt(value))) value = parseInt(value);\r\n      // Bei Lookuplisten / Enums sollen als Fallback die normalen Texte angezeigt werden, wenn es keine Übersetzung für den Key gibt, damit nicht die Keys angezeigt werden.\r\n      let fallback;\r\n      switch (valueFields?.[0]) {\r\n        case \"73801\":\r\n          fallback = row?.[idx?.[\"73802\"]];\r\n          break;\r\n        case \"0Z000\":\r\n          fallback = row?.[idx?.[\"0Z999\"]];\r\n          break;\r\n        default:\r\n          fallback = null;\r\n      }\r\n      const labelWithoutSep = labelFields?.map(labelField => {\r\n        if (typeof labelField === \"string\") {\r\n          if (row?.[idx?.[labelField]] === \", \") return null;\r\n          return row?.[idx?.[labelField]];\r\n        }\r\n        if (row?.[idx?.[labelField?.value]] === \", \") return null;\r\n        return /*#__PURE__*/React.createElement(Xpecto.I18N, {\r\n          value: String(row?.[idx?.[labelField?.value]])?.replaceAll(\"|\", \"_\"),\r\n          context: labelField?.context,\r\n          group: labelField?.group,\r\n          fallback: fallback\r\n        });\r\n      });\r\n      const label = intersperse(labelWithoutSep, \", \");\r\n      return {\r\n        key: value,\r\n        value,\r\n        label\r\n      };\r\n    });\r\n  }\r\n  return [];\r\n}\r\n\r\n/**\r\n * Maps data based on the provided index object.\r\n *\r\n * @param data - The data to be mapped.\r\n * @param index - The index object containing mapping information.\r\n * @returns An array containing mapped data objects.\r\n */\r\nfunction mapDataWithIndex(data, index) {\r\n  const resultArray = [];\r\n  data?.data?.forEach(innerArray => {\r\n    const resultObject = {\r\n      entity: innerArray[index.entity],\r\n      ...Object.fromEntries(Object.entries(index).filter(([k]) => k !== \"entity\").map(([k, v]) => [k, innerArray[v]]))\r\n    };\r\n    resultArray.push(resultObject);\r\n  });\r\n  return resultArray;\r\n}\r\n\r\n/**\r\n * Checks if App exists.\r\n * @param data useApps().data\r\n * @param name appname\r\n * @returns true if App exists, false if not\r\n */\r\nfunction checkAppExists(db, name) {\r\n  if (db?.length === 0) return false;\r\n  return db.findIndex(el => el.name === name) !== -1;\r\n}\r\nfunction isLocalHost(url) {\r\n  if (url.includes(\"localhost\") || url.includes(\"127.0.0.1\")) {\r\n    return \"https://dev-immoexpert.xpecto.live\";\r\n  }\r\n  return url;\r\n}\r\nfunction isNullOrEmpty(data) {\r\n  return data === null || data === undefined || typeof data === \"string\" && data.length === 0 || typeof data === \"number\" && Number.isNaN(data) || Array.isArray(data) && data.length === 0 || typeof data === \"object\" && Object.keys(data).length === 0;\r\n}\r\n\r\n/**\r\n * removes double values from array\r\n *\r\n * usage: db?.data?.filter(onlyUnique);\r\n * @param value value from filter() method\r\n * @param index index from filter() method\r\n * @param array array from filter() method\r\n * @returns filtered array\r\n */\r\nfunction onlyUnique(value, index, array) {\r\n  return array.indexOf(value) === index;\r\n}\r\n\r\n/**\r\n * removes all double objects in an array of objects that have the same specified props\r\n *\r\n * usage: db?.data?.filter((value, index, array) => areOnlyUniqueObjects(value, index, array, [idx?.[fieldId1], idx?.[fieldId2]])\r\n * @param value value from filter() method\r\n * @param index index from filter() method\r\n * @param array array from filter() method\r\n * @param props combination of the props\r\n * @returns filtered array\r\n */\r\nfunction areOnlyUniqueObjects(value, index, array, props) {\r\n  return array?.findIndex(v => props?.every(el => v?.[el] === value?.[el])) === index;\r\n}\r\n\r\n/**\r\n * removes all double rows from the list that have the same value in the specified fieldId\r\n *\r\n * removes all rows where the value in the specified fieldId is empty\r\n * @param dbSelect list\r\n * @param idxSelect list indices\r\n * @param fieldId fieldId of the field that has to be unique\r\n * @returns filtered rows\r\n */\r\nfunction createFilteredSelectList(dbSelect, idxSelect, fieldId) {\r\n  if (isNullOrEmpty(dbSelect?.data)) return {\r\n    data: []\r\n  };\r\n  return {\r\n    data: dbSelect.data.filter((value, index, array) => areOnlyUniqueObjects(value, index, array, [idxSelect?.[fieldId]])).filter(value => !isNullOrEmpty(value?.[idxSelect?.[fieldId]])).sort((a, b) => (a?.[idxSelect?.[fieldId]] || 0) - (b?.[idxSelect?.[fieldId]] || 1))\r\n  };\r\n}\r\n\r\n/**\r\n * get the JSONDataSource with the values of a row from a list\r\n * @param db list\r\n * @param idx list indices\r\n * @param selectedFieldId fieldId of selectedValue\r\n * @param selectedValue value of the selectedFieldId of the selected row\r\n * @returns JSONDataSource from the values of the row\r\n */\r\nfunction getJSONDataSourceFromSelectedItem(db, idx, selectedFieldId, selectedValue) {\r\n  if (db?.data?.length === 0) return {};\r\n  const row = db?.data?.find(el => el?.[idx?.[selectedFieldId]] === selectedValue);\r\n  return Object.fromEntries(Object.entries(idx || {})?.map(([fieldId, value]) => [fieldId, [5, 10].includes(db?.meta?.find(el => el?.id === fieldId)?.type) && !isNullOrEmpty(row?.value) ? dateFns.formatISO(new Date(row?.[value])) : row?.[value]]));\r\n}\r\n\r\n/**\r\n * slice a text (e. g. in a tag)\r\n * @param label text\r\n * @param maxLength max length of text, default 15\r\n * @returns sliced text with ...\r\n */\r\nfunction sliceTagLabel(label, maxLength = 15) {\r\n  if (label?.length <= maxLength) return label;\r\n  return label?.slice(0, maxLength - 3).concat(\"...\");\r\n}\r\n\r\n/**\r\n * translate the values of a lookup-field that can have multiple values (field with lookup list and FL_FieldType 8)\r\n * @param val value of the field\r\n * @param lookupList name of the lookup list\r\n * @returns array with comma elements between the translated elements\r\n */\r\nfunction translateMultipleLookupValuesWithComma(val, lookupList) {\r\n  if (isNullOrEmpty(val)) return null;\r\n  return intersperse(val.split(\",\").map(el => /*#__PURE__*/React.createElement(Xpecto.I18N, {\r\n    value: el,\r\n    context: \"lookup\",\r\n    group: lookupList\r\n  })), \", \");\r\n}\r\nfunction splitArrayList(db, idx, field) {\r\n  if (db?.data && db.data.length > 0) {\r\n    return db.data.map(arr => arr?.[idx?.[field]]).flatMap(el => el?.split(\", \")).filter(value => !isNullOrEmpty(value)).filter(onlyUnique).sort().map(el => [el]);\r\n  }\r\n  return [];\r\n}\r\nfunction createChartData(db, idx, /** data structure to assign a color and a label to the dataset, the key is a unique field from the list to identifiy the dataset */\r\ndataInfo, /** field from list that contains the key of dataInfo */\r\ndataInfoKeyField, /** field from list that contains the number value */\r\nvalueField) {\r\n  if (isNullOrEmpty(db?.data)) {\r\n    return {\r\n      data: [],\r\n      colors: [],\r\n      labels: []\r\n    };\r\n  }\r\n  const itemArray = db.data.map(row => {\r\n    const dataInfoItem = dataInfo[row?.[idx?.[dataInfoKeyField]]] || {};\r\n    if (Object.keys(dataInfoItem).length === 0) return null;\r\n    return {\r\n      value: row?.[idx?.[valueField]] || 0,\r\n      color: dataInfoItem.color,\r\n      label: dataInfoItem.label\r\n    };\r\n  }).filter(val => !isNullOrEmpty(val));\r\n  return itemArray.reduce((acc, val) => {\r\n    acc.data.push(val.value);\r\n    acc.colors.push(val.color);\r\n    acc.labels.push(val.label);\r\n    return acc;\r\n  }, {\r\n    data: [],\r\n    colors: [],\r\n    labels: []\r\n  });\r\n}\r\nfunction getTotalValue(db, idx, field) {\r\n  if (isNullOrEmpty(db?.data)) return 0;\r\n  return db.data.reduce((acc, val) => acc + (val?.[idx?.[field]] || 0), 0);\r\n}\r\nasync function getFilePreview(files) {\r\n  const defaultFilePreview = {\r\n    url: undefined,\r\n    realUrl: undefined,\r\n    type: undefined,\r\n    name: undefined\r\n  };\r\n  const file = files[0]?.originFile;\r\n  if (!file) {\r\n    return defaultFilePreview;\r\n  }\r\n  const fileType = files[0]?.originFile?.type?.split(\"/\")?.[1];\r\n  const realUrl = files[0]?.response;\r\n  try {\r\n    const dataUrl = await convertFileToDataURL(file);\r\n    return {\r\n      url: dataUrl,\r\n      realUrl,\r\n      type: fileType,\r\n      name: file?.name\r\n    };\r\n  } catch (error) {\r\n    logger.logError(\"Error converting file to data URL: \", error);\r\n    return defaultFilePreview;\r\n  }\r\n}\r\n\r\n/**\r\n * checks if list is empty\r\n * @param val list to check\r\n * @returns if list is empty\r\n */\r\nfunction isEmptyList(data) {\r\n  return !data || Array.isArray(data) && data.length === 0;\r\n}\r\n\r\n/**\r\n * checks if object is empty\r\n * @param val object to check\r\n * @returns if object is empty\r\n */\r\nfunction isEmptyObject(data) {\r\n  return !data || typeof data === \"object\" && Object.keys(data).length === 0;\r\n}\r\nfunction convertDateToCalcTerm(date, picker) {\r\n  switch (picker) {\r\n    case CalcTermTypes.Daily:\r\n      return `${dateFns.format(date, \"yyyy\")}M${dateFns.format(date, \"MM\")}`;\r\n    case CalcTermTypes.Weekly:\r\n      return `${dateFns.format(date, \"yyyy\")}KW${String(dateFns.getISOWeek(date)).padStart(2, \"0\")}`;\r\n    case CalcTermTypes.Monthly:\r\n      return `${dateFns.format(date, \"yyyy\")}M${dateFns.format(date, \"MM\")}`;\r\n    case CalcTermTypes.Quarterly:\r\n      return `${dateFns.format(date, \"yyyy\")}Q${String(dateFns.getQuarter(date))}`;\r\n    case CalcTermTypes.HalfYearly:\r\n      {\r\n        const half = Math.floor(date.getMonth() / 6) + 1;\r\n        return `${dateFns.format(date, \"yyyy\")}H${half}`;\r\n      }\r\n    case CalcTermTypes.Yearly:\r\n      return dateFns.format(date, \"yyyy\");\r\n    default:\r\n      return dateFns.format(date, \"yyyy/MM/dd\");\r\n  }\r\n}\r\nfunction formatTemplateI18N(template, values) {\r\n  return template.replace(/{(\\w+)}/g, (_, key) => key in values ? String(values[key]) : `{${key}}`);\r\n}"
