            "text": "// @include(global_helpers)\r\n\r\nconst ONE_HOUR = 60;\r\nconst HOURS_OPTIONS = Array.from({\r\n  length: 9\r\n}, (_, i) => ({\r\n  label: i,\r\n  value: i\r\n}));\r\nconst MINUTES_OPTIONS = Array.from({\r\n  length: 4\r\n}, (_, i) => ({\r\n  label: i * 15,\r\n  value: i * 15\r\n}));\r\nconst TIME_OPTIONS = [15, 30, 45, 60, 120, 240];\r\nconst TIME_BUTTON_LABELS = {\r\n  15: \"15 Min\",\r\n  30: \"30 Min\",\r\n  45: \"45 Min\",\r\n  60: \"1 Std\",\r\n  120: \"2 Std\",\r\n  240: \"4 Std\"\r\n};\r\nconst PieChart = () => {\r\n  const {\r\n    data: dbCaseTime,\r\n    indices: idxCaseTime\r\n  } = useAvailableList(\"xpecto-cases_caseTime.case\");\r\n  const caseTimeSum = React.useMemo(() => {\r\n    const timeSumRow = dbCaseTime?.data?.find(x => x?.[idxCaseTime?.D9904] === \"Gesamtaufwand\");\r\n    return timeSumRow?.[idxCaseTime?.D9800] ? `${(parseInt(timeSumRow?.[idxCaseTime?.D9800]) / ONE_HOUR).toString()}h` : \"0\";\r\n  }, [dbCaseTime]);\r\n  const caseTimeChartData = React.useMemo(() => {\r\n    const caseTimeChartDataInternal = [];\r\n    if (!isNullOrEmpty(dbCaseTime?.data)) {\r\n      const dataWithoutTodayAndSum = dbCaseTime?.data?.filter(x => ![\"Gesamtaufwand\", \"Mein heutiger Aufwand\"].includes(x?.[idxCaseTime?.D9904]));\r\n      dataWithoutTodayAndSum?.forEach((x, i) => {\r\n        if (x?.[idxCaseTime?.D9800] > 0) {\r\n          caseTimeChartDataInternal.push({\r\n            key: i,\r\n            name: x[idxCaseTime?.D9904],\r\n            value: x[idxCaseTime?.D9800] / ONE_HOUR\r\n          });\r\n        }\r\n      });\r\n    }\r\n    const chartData = {\r\n      labels: caseTimeChartDataInternal.map(row => row.name),\r\n      datasets: [{\r\n        data: caseTimeChartDataInternal.map(row => row.value)\r\n      }]\r\n    };\r\n    return chartData;\r\n  }, [dbCaseTime]);\r\n  return /*#__PURE__*/React.createElement(Xpecto.Charts.Doughnut, {\r\n    data: caseTimeChartData,\r\n    height: 275,\r\n    options: {\r\n      cutout