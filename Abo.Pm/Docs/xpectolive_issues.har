        "response": {
          "status": 200,
          "content": {
            "mimeType": "application/javascript",
            "text": "function openAppInCurrentTab(history, location, appName, entity, owner, key, alias, targetRoute) {\r\n  history.push({\r\n    pathname: `/${targetRoute || \"app\"}/${appName}/${entity}${alias ? `.${alias}/` : \"/\"}${owner}/${key}`,\r\n    search: location !== \"\" && location.search\r\n  });\r\n}\r\nfunction openSingleAppInNewTab(appName, filter, targetRoute) {\r\n  window.open(`/${targetRoute || \"app\"}/${appName}${filter ? `?filter=${filter}` : \"\"}`, \"_blank\");\r\n}\r\nfunction openAppInNewTab(appName, entity, owner, key, alias, filter, targetRoute) {\r\n  window.open(`/${targetRoute || \"app\"}/${appName}/${entity}${alias ? `.${alias}/` : \"/\"}${owner}/${key}${filter ? `?filter=${filter}` : \"\"}`, \"_blank\");\r\n}\r\n\r\n/**\r\n * Opens specific tasks in another app(not displayed in the navigation) with\r\n * default filter value (appListContext) either as a datapane list view\r\n * or (if RIO is selected) as a datapane entity\r\n *\r\n * currentEntity.entity needs to be targetTable e.g \"B0\"\r\n * targetRoute could be app or config. By default app\r\n */\r\nfunction openAppInListContext(appName, currentEntity, redirectEntity, targetTab, targetRoute, filter) {\r\n  const contextVal = encodeURIComponent(`{\"${currentEntity.entity}\":{ \"dak\":\"${currentEntity.dak}\", \"id\":\"${currentEntity.key}\", \"owner\":\"${currentEntity.owner}\", \"entity\":\"${currentEntity.entity}\" }}`);\r\n  const currentUrl = encodeURIComponent(window.location.href);\r\n  // if no entity/owner/key selected => list view of all pre-filtered tasks\r\n  const selectedRio = redirectEntity.entity !== \"\" && redirectEntity.owner !== \"\" && redirectEntity.key !== \"\" ? `/${redirectEntity.entity}/${redirectEntity.owner}/${redirectEntity.key}` : \"\";\r\n  window.open(`/${targetRoute || \"app\"}/${appName}${selectedRio}?appListContext=${contextVal}&url=${currentUrl}${filter ? `&filter=${filter}` : \"\"}`, targetTab || \"_self\");\r\n}"
          }
        }
